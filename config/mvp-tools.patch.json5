{
  tools: {
    allow: [
      "read",
      "write",
      "edit",
      "image",
      "session_status",
    ],
    deny: [
      "exec",
      "process",
      "apply_patch",
      "browser",
      "sessions_spawn",
      "sessions_send",
      "sessions_yield",
      "subagents",
    ],
    fs: {
      workspaceOnly: true,
    },
    exec: {
      applyPatch: {
        enabled: false,
        workspaceOnly: true,
      },
    },
    elevated: {
      enabled: false,
    },
  },
}
